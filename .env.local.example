# 时区（存入数据库的时间为北京时间，不设则默认 Asia/Shanghai）
TZ=Asia/Shanghai

# 数据库
DATABASE_URL=mysql://root:root@localhost:3306/fzzs

# Cookie 签名密钥（生成：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"）
COOKIE_SECRET=

# 站点地址
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 阿里云基础（短信 + OSS 共用）
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=

# 短信服务
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=

# OSS 对象存储
OSS_REGION=oss-cn-shenzhen
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_SIGNED_URL_EXPIRES_SECONDS=3600

# 微信支付
WECHAT_PAY_APPID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_V3_KEY=
# base64 -i apiclient_key.pem | tr -d '\n'
WECHAT_PAY_PRIVATE_KEY_BASE64=
WECHAT_PAY_CERT_SERIAL_NO=
# base64 -i pub_key.pem | tr -d '\n'
WECHAT_PAY_PUBLIC_KEY_BASE64=
WECHAT_PAY_PUBLIC_KEY_ID=
WECHAT_PAY_NOTIFY_URL=http://localhost:3000/api/payments/wechat/notify
